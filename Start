import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.datasets import load_iris
from sklearn.model_selection import train_test_split
from sklearn.tree import DecisionTreeClassifier, plot_tree
from sklearn.metrics import accuracy_score, classification_report, confusion_matrix
# Load the Iris dataset
iris = load_iris()

# Create a DataFrame
df = pd.DataFrame(data=iris.data, columns=iris.feature_names)

# Add the target column (numeric values)
df['target'] = iris.target

# Optional: Map target numbers to class names (for readability)
df['target'] = df['target'].map({i: name for i, name in enumerate(iris.target_names)})

# Print first 5 rows to check the data
print(df.head())
# Check data types and null values
print("\n--- Data Info ---")
print(df.info())

# Summary statistics
print("\n--- Data Description ---")
print(df.describe())

# Class distribution
print("\n--- Target Class Distribution ---")
print(df['target'].value_counts())

# Plot class distribution (optional, shows in a window)
sns.countplot(x='target', data=df)
plt.title('Target Class Distribution')
plt.show()
# Prepare features (X) and target (y)
X = df[iris.feature_names]
y = df['target']

# Split data into Training and Testing sets
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42
)

# Print shape of the splits to verify
print("\n--- Data Split ---")
print(f"Training set size: {X_train.shape[0]} samples")
print(f"Testing set size: {X_test.shape[0]} samples")
# Initialize the Decision Tree Classifier
clf = DecisionTreeClassifier(random_state=42, max_depth=3)

# Train (fit) the model
clf.fit(X_train, y_train)

# Print model training complete
print("\n--- Model Training Complete ---")
# Visualize the decision tree
plt.figure(figsize=(12,8))
plot_tree(
    clf,
    feature_names=iris.feature_names,
    class_names=iris.target_names,
    filled=True,
    rounded=True,
    fontsize=12
)
plt.title("Decision Tree Visualization")
plt.show()
# Predict on test data
y_pred = clf.predict(X_test)

# Calculate accuracy
accuracy = accuracy_score(y_test, y_pred)
print(f"\n--- Model Accuracy: {accuracy:.2f} ---")

# Detailed classification report
print("\n--- Classification Report ---")
print(classification_report(y_test, y_pred))

# Confusion matrix
cm = confusion_matrix(y_test, y_pred)
print("\n--- Confusion Matrix ---")
print(cm)

# Optional: Plot confusion matrix heatmap
plt.figure(figsize=(6,5))
sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
            xticklabels=iris.target_names,
            yticklabels=iris.target_names)
plt.xlabel('Predicted')
plt.ylabel('Actual')
plt.title('Confusion Matrix Heatmap')
plt.show()
print("\n--- Summary ---")
print(f"Dataset used: Iris flower dataset")
print(f"Training samples: {X_train.shape[0]}, Testing samples: {X_test.shape[0]}")
print(f"Decision Tree max depth: 3")
print(f"Model accuracy on test set: {accuracy:.2f}")

print("""
Analysis:
- The model performs well with over 90% accuracy.
- The tree depth controls model complexity; deeper trees might overfit.
- Confusion matrix shows which classes are confused.
- Visualizing the tree helps understand decision boundaries.
""")

